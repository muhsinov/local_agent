APP_NAME=Local Agent Demo
APP_VERSION=0.1.0
HOST=127.0.0.1
PORT=8000
DATABASE_PATH=data/local_agent.db
UPLOAD_DIRECTORY=data/uploads
EXTRACTED_TEXT_DIRECTORY=data/extracted
VECTOR_STORE_DIRECTORY=data/vector_store
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_KEEP_ALIVE=2m
OLLAMA_THINK=false
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=512
CHAT_HISTORY_MESSAGES=6
MAX_CHAT_MESSAGE_CHARS=4000
CHAT_BUSY_TIMEOUT_SECONDS=5
DOCUMENT_BUSY_TIMEOUT_SECONDS=10
UPLOAD_CHUNK_SIZE_KB=256
MAX_PDF_PAGES=100
MAX_PDF_PAGE_CONTENT_MB=20
MAX_EXTRACTED_CHARS=2000000
MAX_DOCX_UNCOMPRESSED_MB=50
MAX_DOCX_ZIP_ENTRIES=2000
MAX_DOCX_COMPRESSION_RATIO=100
DOCUMENT_PREVIEW_CHARS=5000
MAX_DOCUMENT_LIST_LIMIT=100
MAX_ORIGINAL_FILENAME_CHARS=180
REQUEST_TIMEOUT_SECONDS=90
MAX_AGENT_ITERATIONS=5
MAX_FILE_SIZE_MB=10
